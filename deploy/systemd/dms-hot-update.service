[Unit]
Description=DMS Hot Update Stack
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=Charles
Group=Charles
WorkingDirectory=/opt/DMS
ExecStart=/opt/DMS/hot-update.sh start
ExecStop=/opt/DMS/hot-update.sh stop
RemainAfterExit=yes
TimeoutStartSec=0
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
